# ─────────────────────────────────────────────────────────────
# Aesther AI — Environment Variables
# Copy this file to .env and fill in every value before running.
# ─────────────────────────────────────────────────────────────

# ── Email (Nodemailer / Gmail SMTP) ──────────────────────────
NODE_MAILER_EMAIL=your_gmail_address@gmail.com
NODE_MAILER_GMAIL_APP_PASSWORD=your_gmail_app_password

# ── Pusher (Real-time chat) ───────────────────────────────────
# Create an app at https://pusher.com → Channels
NEXT_PUBLIC_PUSHER_APP_ID=your_pusher_app_id
NEXT_PUBLIC_PUSHER_APP_KEY=your_pusher_app_key
NEXT_PUBLIC_PUSHER_APP_SECRET=your_pusher_app_secret
NEXT_PUBLIC_PUSHER_APP_CLUSTOR=your_pusher_cluster    # e.g. ap2, us2, eu

# ── OpenAI ────────────────────────────────────────────────────
# Get key at https://platform.openai.com/api-keys
OPEN_AI_KEY=your_openai_api_key_here

# ── UploadCare (File uploads) ────────────────────────────────
# Get keys at https://app.uploadcare.com/accounts/keys/
NEXT_PUBLIC_UPLOAD_CARE_PUBLIC_KEY=your_uploadcare_public_key
UPLOAD_CARE_SECRET_KEY=your_uploadcare_secret_key

# ── Clerk (Authentication) ────────────────────────────────────
# Get keys at https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Clerk redirect URLs (keep these as-is for local development)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up

# ── Stripe (Payments) ────────────────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISH_KEY=pk_test_your_stripe_publishable_key

# ── Database (MongoDB Atlas via Prisma) ──────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
DATABASE_URL=mongodb+srv://your_db_user:your_db_password@your_cluster.mongodb.net/your_database_name

# ── Cloudways (External content API — optional) ──────────────
CLOUDWAYS_POSTS_URL=https://your_cloudways_domain/wp-json/wp/v2/posts
CLOUDWAYS_FEATURED_IMAGES_URL=https://your_cloudways_domain/wp-json/wp/v2/media
CLOUDWAYS_UPLOADS_URL=https://your_cloudways_domain/wp-content/uploads
CLOUDWAYS_USERS_URL=https://your_cloudways_domain/wp-json/wp/v2/users
